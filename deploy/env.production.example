# Production environment — copy to the repository root as ".env" on the server
# and fill in every secret. Used by docker-compose AND by the application.
#   cp deploy/env.production.example .env

# Domain served by Caddy. With a real domain, HTTPS certificates are automatic.
# For a quick test without a domain use: http://<server-ip>
APP_DOMAIN=gestionale.example.com

APP_NAME="Gestionale Muratori"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://gestionale.example.com
APP_TIMEZONE=Europe/Rome

DB_NAME=gestionale_muratori
DB_USER=gestionale
# Generate strong values, e.g.:  openssl rand -base64 24
DB_PASS=CHANGE-ME-app-db-password
DB_ROOT_PASS=CHANGE-ME-root-db-password

# Cookies only over HTTPS (set false only if serving plain HTTP on a LAN).
SESSION_SECURE=true

# Business rule: block reservations that would drive stock negative.
ALLOW_NEGATIVE_STOCK=false

# Giornale dei Lavori: auto-fill weather from Open-Meteo (outbound HTTPS, no key).
# Set to false for air-gapped installs; the daily log then takes manual weather.
WEATHER_ENABLED=true
WEATHER_TIMEOUT=5
