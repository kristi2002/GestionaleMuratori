# Copy this file to ".env" and adjust for your machine.
# Default values match a stock XAMPP install (MySQL root with no password).
# Real environment variables override values in this file (Docker/tests).

APP_NAME="Gestionale Muratori"
APP_ENV=local
# Debug is OFF by default (prod-safe). Enable only for local development.
APP_DEBUG=true
APP_URL=http://localhost/GestionaleMuratori/public

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gestionale_muratori
DB_USER=root
DB_PASS=

# --- Optional (defaults shown) ------------------------------------------------
# Send the session cookie only over HTTPS. Default: inferred from APP_URL scheme.
#SESSION_SECURE=false
# Idle timeout for authenticated sessions, in seconds (default 8 hours).
#SESSION_IDLE_TIMEOUT=28800
# Login rate limiting.
#LOGIN_MAX_ATTEMPTS=5
#LOGIN_MAX_ATTEMPTS_IP=20
#LOGIN_WINDOW_MINUTES=15
# Allow stock to go negative on reservations/adjustments (default: block).
#ALLOW_NEGATIVE_STOCK=false
